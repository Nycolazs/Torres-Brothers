rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function systemExists() {
      return exists(/databases/$(database)/documents/system/main);
    }

    function systemData() {
      return get(/databases/$(database)/documents/system/main).data;
    }

    function companyUid() {
      return systemData().adminUid;
    }

    function isAdmin() {
      return isSignedIn() && systemExists() && companyUid() == request.auth.uid;
    }

    function currentUserProfileExists() {
      return isSignedIn() &&
        exists(/databases/$(database)/documents/users/$(request.auth.uid)/profile/main);
    }

    function currentUserProfile() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)/profile/main).data;
    }

    function hasCompanyAccess() {
      return currentUserProfileExists() &&
        currentUserProfile().accessStatus == 'approved';
    }

    function isOwner(uid) {
      return isSignedIn() && request.auth.uid == uid;
    }

    function isCompanyCollection(uid) {
      return systemExists() && uid == companyUid();
    }

    function validProfileBase(uid) {
      return request.resource.data.uid == uid &&
        request.resource.data.email == request.auth.token.email &&
        request.resource.data.companyName == 'Torres Brothers';
    }

    function ownerCanCreateProfile(uid) {
      return isOwner(uid) &&
        validProfileBase(uid) &&
        request.resource.data.role == (isAdmin() ? 'admin' : 'user') &&
        request.resource.data.accessStatus == (isAdmin() ? 'approved' : 'pending');
    }

    function ownerCanUpdateProfile(uid) {
      return isOwner(uid) &&
        request.resource.data.uid == resource.data.uid &&
        request.resource.data.email == resource.data.email &&
        request.resource.data.companyName == 'Torres Brothers' &&
        request.resource.data.role == resource.data.role &&
        request.resource.data.accessStatus == resource.data.accessStatus &&
        request.resource.data.diff(resource.data).changedKeys().hasOnly([
          'name',
          'phone',
          'photoUrl',
          'updatedAt',
          'companyName',
        ]);
    }

    function adminCanUpdateProfile() {
      return isAdmin() &&
        request.resource.data.uid == resource.data.uid &&
        request.resource.data.email == resource.data.email &&
        request.resource.data.companyName == 'Torres Brothers';
    }

    match /system/{docId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() &&
        docId == 'main' &&
        !systemExists() &&
        request.resource.data.adminUid == request.auth.uid &&
        request.resource.data.primaryCompanyName == 'Torres Brothers';
      allow update: if isAdmin() &&
        docId == 'main' &&
        request.resource.data.adminUid == resource.data.adminUid &&
        request.resource.data.primaryCompanyName == resource.data.primaryCompanyName;
      allow delete: if false;
    }

    match /users/{userId}/profile/{profileId} {
      allow read: if isOwner(userId) || isAdmin();
      allow create: if profileId == 'main' && ownerCanCreateProfile(userId);
      allow update: if profileId == 'main' && (ownerCanUpdateProfile(userId) || adminCanUpdateProfile());
      allow delete: if isOwner(userId);
    }

    match /{path=**}/profile/{profileId} {
      allow read: if isAdmin();
    }

    match /users/{userId}/categories/{document=**} {
      allow read, write: if isSignedIn() && isCompanyCollection(userId) && hasCompanyAccess();
    }

    match /users/{userId}/transactions/{document=**} {
      allow read, write: if isSignedIn() && isCompanyCollection(userId) && hasCompanyAccess();
    }

    match /users/{userId}/bankAccounts/{document=**} {
      allow read, write: if isSignedIn() && isCompanyCollection(userId) && hasCompanyAccess();
    }

    match /users/{userId}/costCenters/{document=**} {
      allow read, write: if isSignedIn() && isCompanyCollection(userId) && hasCompanyAccess();
    }

    match /users/{userId}/budgets/{document=**} {
      allow read, write: if isSignedIn() && isCompanyCollection(userId) && hasCompanyAccess();
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
